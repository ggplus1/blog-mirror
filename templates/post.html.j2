<!DOCTYPE html>
<html lang="ko">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>{{ post.title }} | {{ site_title }}</title>
<meta name="description" content="{{ post.summary }}">
<meta name="keywords" content="{{ keywords }}">
<meta name="author" content="{{ site_title }}">
<meta name="robots" content="index, follow">

<!-- 핵심: canonical 을 네이버 원문으로 지정 → 구글에 "원본은 네이버" 힌트 -->
<link rel="canonical" href="{{ post.original_url }}">

<!-- 3초 후 네이버 원문으로 자동 이동 -->
<meta http-equiv="refresh" content="3;url={{ post.original_url }}">

<!-- Open Graph -->
<meta property="og:type" content="article">
<meta property="og:title" content="{{ post.title }}">
<meta property="og:description" content="{{ post.summary }}">
<meta property="og:url" content="{{ post.original_url }}">
<meta property="og:site_name" content="{{ site_title }}">
<meta property="article:published_time" content="{{ post.published }}">

<!-- JSON-LD: 원본을 네이버로 명시 -->
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "Article",
  "headline": {{ post.title|tojson }},
  "description": {{ post.summary|tojson }},
  "datePublished": "{{ post.published }}",
  "author": { "@type": "Organization", "name": {{ site_title|tojson }} },
  "publisher": { "@type": "Organization", "name": {{ site_title|tojson }} },
  "mainEntityOfPage": {{ post.original_url|tojson }}
}
</script>

<style>
  :root {
    --fg: #222;
    --muted: #666;
    --accent: #03c75a;
    --bg: #fff;
    --border: #e5e7eb;
  }
  * { box-sizing: border-box; }
  body {
    font-family: -apple-system, BlinkMacSystemFont, "Malgun Gothic", "Apple SD Gothic Neo", sans-serif;
    margin: 0; padding: 0; color: var(--fg); background: var(--bg);
    line-height: 1.7;
  }
  main {
    max-width: 640px; margin: 0 auto; padding: 4rem 1.5rem 2rem;
    text-align: center;
  }
  .company {
    color: var(--muted); font-size: 0.9rem; margin-bottom: 2rem;
  }
  h1 {
    font-size: 1.5rem; line-height: 1.4; margin: 0 0 1rem;
    word-break: keep-all;
  }
  .meta { color: var(--muted); font-size: 0.85rem; margin-bottom: 2rem; }
  .summary {
    color: #444; font-size: 1rem; margin: 0 0 2.5rem;
    padding: 1.5rem; background: #f8fafc; border-radius: 8px;
    text-align: left; word-break: keep-all;
  }
  .cta { margin: 2rem 0; }
  .cta a {
    display: inline-block; padding: 0.9rem 2rem; background: var(--accent);
    color: #fff; text-decoration: none; border-radius: 6px; font-weight: 600;
    font-size: 1.05rem;
  }
  .cta a:hover { opacity: 0.9; }
  .redirect-notice { margin-top: 1.5rem; font-size: 0.85rem; color: var(--muted); }
  .redirect-notice .count {
    display: inline-block; min-width: 1em; font-weight: 600; color: var(--accent);
  }
  .home-link { margin-top: 3rem; font-size: 0.85rem; }
  .home-link a { color: var(--muted); text-decoration: none; }
  .home-link a:hover { text-decoration: underline; }
</style>
</head>
<body>

<main>
  <div class="company">{{ site_title }}</div>

  <article>
    <h1>{{ post.title }}</h1>
    <div class="meta">발행일: {{ post.published[:10] }}</div>

    <div class="summary">{{ post.summary }}</div>

    <div class="cta">
      <a href="{{ post.original_url }}" rel="noopener">네이버 블로그에서 전체 내용 보기 →</a>
    </div>

    <div class="redirect-notice">
      <span class="count" id="countdown">3</span>초 후 네이버 블로그로 자동 이동합니다.
    </div>
  </article>

  <div class="home-link">
    <a href="{{ site_url }}/">← 전체 글 목록</a>
  </div>
</main>

<script>
  (function() {
    var el = document.getElementById('countdown');
    var n = 3;
    var timer = setInterval(function() {
      n -= 1;
      if (n <= 0) { clearInterval(timer); el.textContent = '0'; }
      else { el.textContent = String(n); }
    }, 1000);
  })();
</script>

</body>
</html>
